---
import LoadingSpinner from './LoadingSpinner.astro';
import ServerCard from './ServerCard.astro';
---

<div class="max-w-4xl mx-auto">
  <div class="text-center mb-8">
    <p class="text-white text-xl">Monitoraggio disponibilità in tempo reale</p>
    <p class="text-white text-sm mt-2">Ultimo aggiornamento: <span id="lastUpdate" class="font-mono"></span></p>
    <h1 class="text-3xl font-bold text-white mt-5">KS-A | Intel i7-6700k</h1>
  </div>

  <div id="loading">
    <LoadingSpinner />
  </div>

  <div id="status" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 hidden"></div>
</div>

<script>
const datacenterInfo = {
  'fra': { 
    name: 'Frankfurt (Limburg)',
    flag: '🇩🇪',
    country: 'de'
  },
  'gra': {
    name: 'Gravelines',
    flag: '🇫🇷',
    country: 'fr'
  },
  'lon': {
    name: 'London (Erith)',
    flag: '🇬🇧',
    country: 'gb'
  },
  'rbx': {
    name: 'Roubaix',
    flag: '🇫🇷',
    country: 'fr'
  },
  'sbg': {
    name: 'Strasbourg',
    flag: '🇫🇷',
    country: 'fr'
  }
};

let lastStates = {};
let notificationPermission = false;

async function setupNotifications() {
  if ('Notification' in window && Notification.permission !== 'denied') {
    const permission = await Notification.requestPermission();
    notificationPermission = permission === 'granted';
  }
}

function formatDate(date) {
  return `${date.toLocaleTimeString()} ${date.toLocaleDateString()}`;
}

async function checkAvailability() {
  try {
    const response = await fetch('https://eu.api.ovh.com/v1/dedicated/server/datacenter/availabilities?planCode=24ska01', {
      headers: {'accept': 'application/json'}
    });
    
    if (!response.ok) throw new Error('Network response was not ok');
    
    const data = await response.json();
    processData(data);
    document.getElementById('lastUpdate').textContent = formatDate(new Date());
  } catch (error) {
    console.error('Error:', error);
  }
}

function processData(data) {
  const statusContainer = document.getElementById('status');
  const loadingElement = document.getElementById('loading');
  let html = '';

  data[0].datacenters.forEach(dc => {
    if (!datacenterInfo[dc.datacenter]) return;
    
    const info = datacenterInfo[dc.datacenter];
    const isAvailable = dc.availability !== 'unavailable';
    
    if (isAvailable && (!lastStates[dc.datacenter] || lastStates[dc.datacenter] !== isAvailable)) {
      sendNotification(`${info.flag} ${info.name} disponibile!`);
    }

    html += `
      <div class="p-6 rounded-lg shadow-sm transition-all duration-200 ${
        isAvailable 
          ? 'bg-black hover:shadow-md border-2 border-green-600' 
          : 'bg-black border-2 border-red-600'
      }">
        <div class="flex items-center mb-3">
          <span class="text-2xl mr-2">${info.flag}</span>
          <h5 class="text-md text-white">${info.name}</h5>
        </div>
        
        <div class="flex justify-between items-center">
          <span class="text-sm ${isAvailable ? 'text-green-600' : 'text-white'}">
            ${isAvailable ? '🟢 Disponibile' : '🔴 Esaurito'}
          </span>
          ${isAvailable ? `
            <a href="https://eco.ovhcloud.com/it/kimsufi/ks-a/" 
               target="_blank"
               class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-sm font-medium transition-colors">
              Acquista ora
            </a>
          ` : ''}
        </div>
      </div>
    `;
  });

  statusContainer.innerHTML = html;
  loadingElement.classList.add('hidden');
  statusContainer.classList.remove('hidden');
  lastStates = Object.fromEntries(data[0].datacenters.map(dc => [dc.datacenter, dc.availability]));
}

function sendNotification(message) {
  if (notificationPermission) {
    const notification = new Notification('🚨 Server Disponibile', {
      body: message,
      icon: 'https://img.icons8.com/fluency/96/server.png',
      vibrate: [200, 100, 200],
      tag: 'server-availability',
      renotify: true
    });

    notification.onclick = function(event) {
      event.preventDefault();
      window.open('https://eco.ovhcloud.com/it/kimsufi/ks-a/', '_blank');
      notification.close();
    };
  }
}

// Initialize
setupNotifications();
checkAvailability();

// Set up intervals with error handling
const checkInterval = setInterval(checkAvailability, 10000);
const loadingInterval = setInterval(() => {
  document.getElementById('loading').classList.remove('hidden');
  document.getElementById('status').classList.add('hidden');
}, 9500);

// Cleanup on page unload
window.addEventListener('unload', () => {
  clearInterval(checkInterval);
  clearInterval(loadingInterval);
});
</script>